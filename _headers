/*
  # Forcer HTTPS et sécuriser les connexions
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Empêcher le sniffing MIME (téléchargement de fichiers malveillants)
  X-Content-Type-Options: nosniff

  # Contrôler les infos de référent envoyées aux sites tiers
  Referrer-Policy: strict-origin-when-cross-origin

  # Désactiver les fonctionnalités navigateur non utilisées
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()

  # Protection XSS (anciens navigateurs)
  X-XSS-Protection: 1; mode=block

  # Empêcher l'affichage du site dans une iframe (clickjacking)
  X-Frame-Options: SAMEORIGIN

  # Content Security Policy — autorise uniquement les ressources légitimes
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://identity.netlify.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; media-src 'self'; connect-src 'self' https://formspree.io https://identity.netlify.com https://api.netlify.com; frame-ancestors 'none';

# Admin Decap CMS — règle plus spécifique, appliquée après /* pour l'écraser
/admin/*
  Content-Security-Policy: default-src 'self' 'unsafe-inline' 'unsafe-eval' https:; img-src 'self' data: blob: https:; media-src 'self' blob:; connect-src 'self' https:; frame-src 'self' https:; worker-src 'self' blob:;
  X-Frame-Options: SAMEORIGIN
