{
  "buildCommand": null,
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "redirects": [
    {
      "source": "/callback",
      "destination": "/api/callback"
    },
    {
      "source": "/auth",
      "destination": "/api/auth"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.pronuptia-lyon.fr" }],
      "destination": "https://pronuptia-lyon.fr/$1",
      "permanent": true
    }
  ]
}
